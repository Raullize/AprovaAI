# ── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
# Connection string do PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/aprovaai"

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Authentication (JWT) ──────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# ── Upload / Storage ─────────────────────────────────────────────────────────
# Diretório local para armazenar imagens. Padrão: ./uploads
UPLOAD_DIR=./uploads
